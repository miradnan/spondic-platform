# ============================================================================
# Spondic API Service — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Docker Compose sets this automatically. For local dev with Postgres in Docker:
DATABASE_URL=postgres://spondic:spondic@localhost:5432/spondic?sslmode=disable

# ── Authentication (Clerk) ───────────────────────────────────────────────────
# Clerk JWKS URL for JWT verification.
# How to get it:
#   1. Go to https://dashboard.clerk.com
#   2. Select your application
#   3. Go to API Keys → Advanced
#   4. Copy the JWKS URL (format: https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json)
CLERK_JWKS_URL=

# ── AWS S3 (Document Storage) ───────────────────────────────────────────────
# S3 bucket for storing uploaded RFP documents and knowledge base files.
# How to get credentials:
#   1. Go to AWS Console → IAM → Users → Create User
#   2. Attach policy: AmazonS3FullAccess (or scoped to your bucket)
#   3. Create Access Key → copy Key ID and Secret
#   4. Go to S3 → Create Bucket → note the name and region
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=spondic-docs

# ── AI Service ───────────────────────────────────────────────────────────────
# URL of the Python AI service (FastAPI). Set automatically in Docker Compose.
AI_SERVICE_URL=http://localhost:8000

# ── Stripe Billing ───────────────────────────────────────────────────────────
# Stripe API keys for subscription management and billing.
# How to get them:
#   1. Go to https://dashboard.stripe.com/apikeys
#   2. Copy "Secret key" (starts with sk_test_ for test mode, sk_live_ for production)
#   3. For webhook secret:
#      a. Go to Developers → Webhooks → Add Endpoint
#      b. Set endpoint URL: https://api.spondic.com/api/billing/webhook
#      c. Select events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
#      d. Copy the "Signing secret" (starts with whsec_)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Salesforce CRM Integration ───────────────────────────────────────────────
# OAuth credentials for Salesforce integration.
# How to get them:
#   1. Go to Salesforce Setup → App Manager → New Connected App
#   2. Enable OAuth Settings
#   3. Set callback URL: https://api.spondic.com/api/integrations/crm/salesforce/callback
#   4. Select scopes: api, refresh_token, offline_access
#   5. Copy Consumer Key (client_id) and Consumer Secret (client_secret)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ── HubSpot CRM Integration ─────────────────────────────────────────────────
# OAuth credentials for HubSpot integration.
# How to get them:
#   1. Go to https://developers.hubspot.com → Create App
#   2. Go to Auth tab
#   3. Set redirect URL: https://api.spondic.com/api/integrations/crm/hubspot/callback
#   4. Select scopes: crm.objects.deals.read, crm.objects.deals.write
#   5. Copy App ID (client_id) and Client Secret
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Email Notifications (AWS SES) ────────────────────────────────────────────
# AWS SES for sending email notifications (uses same AWS credentials as S3).
# How to set up:
#   1. Go to AWS Console → SES → Verified Identities
#   2. Verify your sending domain (e.g., spondic.com) or email address
#   3. For production: request to move out of SES sandbox
#   4. Set the "From" email below (must be a verified identity)
SES_FROM_EMAIL=noreply@spondic.com

# ── Slack Integration ────────────────────────────────────────────────────────
# Note: Slack webhooks are configured per-organization in the Admin → Integrations page.
# No global env var needed — each org provides their own webhook URL.
# How users get a Slack webhook URL:
#   1. Go to https://api.slack.com/messaging/webhooks
#   2. Create a Slack App → Enable Incoming Webhooks
#   3. Add New Webhook to Workspace → select channel
#   4. Copy the webhook URL

# ── Microsoft Teams Integration ──────────────────────────────────────────────
# Note: Teams webhooks are configured per-organization in the Admin → Integrations page.
# How users get a Teams webhook URL:
#   1. In Teams, go to the channel → Connectors → Incoming Webhook
#   2. Name it (e.g., "Spondic Alerts") → Create
#   3. Copy the webhook URL
