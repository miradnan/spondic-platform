# ============================================================================
# Spondic AI Service — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Groq (LLM for Answer Generation) ────────────────────────────────────────
# Groq provides fast LLM inference for drafting RFP answers and extracting questions.
# Model used: llama-3.3-70b-versatile (fallback: llama-3.1-8b-instant)
# How to get your API key:
#   1. Go to https://console.groq.com
#   2. Sign up / Sign in
#   3. Go to API Keys → Create API Key
#   4. Copy the key (starts with gsk_)
# Free tier: 30 RPM, 14,400 RPD — sufficient for development
# Production: upgrade at https://console.groq.com/settings/billing
GROQ_API_KEY=
# Models — override to use different Groq-hosted models for chat vs RFP drafting
CHAT_MODEL=llama-3.3-70b-versatile
RFP_DRAFT_MODEL=llama-3.3-70b-versatile

# ── OpenAI (Text Embeddings) — OPTIONAL ──────────────────────────────────────
# Used for text-embedding-3-small if you prefer OpenAI embeddings over local.
# The app defaults to LOCAL embeddings (sentence-transformers/all-MiniLM-L6-v2)
# which require NO API key. Only set this if you want higher-quality OpenAI embeddings.
# How to get your API key:
#   1. Go to https://platform.openai.com/api-keys
#   2. Create new secret key
#   3. Copy the key (starts with sk-)
# Cost: ~$0.02 per 1M tokens for text-embedding-3-small
OPENAI_API_KEY=

# ── Weaviate (Vector Database for RAG) ───────────────────────────────────────
# Weaviate stores document embeddings for semantic search (RAG retrieval).
# In Docker Compose: http://weaviate:8080 (internal) / http://localhost:8081 (external)
# For Weaviate Cloud: https://your-cluster.weaviate.network
# How to set up locally:
#   1. Docker Compose starts Weaviate automatically on port 8081
#   2. For local dev without Docker: docker run -p 8081:8080 cr.weaviate.io/semitechnologies/weaviate:1.27.2
# How to set up Weaviate Cloud (production):
#   1. Go to https://console.weaviate.cloud
#   2. Create a cluster
#   3. Copy the cluster URL
WEAVIATE_URL=http://localhost:8081

# ── AWS S3 (Document Retrieval) ──────────────────────────────────────────────
# The AI service downloads uploaded documents from S3 for parsing and indexing.
# Uses the same bucket and credentials as the Go API service.
# See api/.env.example for setup instructions.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=spondic-docs
