# ============================================================================
# Spondic App (React) — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

# ── Business Name ────────────────────────────────────────────────────────────
# Display name used in the UI, document title, and branding fallback.
VITE_BUSINESS_NAME=Spondic

# ── Clerk Authentication ─────────────────────────────────────────────────────
# Clerk publishable key for frontend authentication.
# How to get it:
#   1. Go to https://dashboard.clerk.com
#   2. Select your application (or create one)
#   3. Go to API Keys
#   4. Copy the "Publishable key" (starts with pk_test_ or pk_live_)
# Features enabled: Email/password, Google SSO, Microsoft SSO, Organizations
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── API URL ──────────────────────────────────────────────────────────────────
# Backend API base URL.
# In development: leave EMPTY to use Vite proxy (avoids CORS issues).
#   Vite proxy forwards /api/* to http://localhost:8080 automatically.
# In production: set to full API URL (e.g., https://api.spondic.com)
VITE_API_URL=
