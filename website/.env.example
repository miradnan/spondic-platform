# ============================================================================
# Spondic Website (Next.js) — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

# ── App URL ──────────────────────────────────────────────────────────────────
# URL of the Spondic app (where "Get Started" / "Sign In" buttons link to).
NEXT_PUBLIC_APP_URL=https://app.spondic.com

# ── Domain ───────────────────────────────────────────────────────────────────
# Used for SEO metadata, canonical URLs, and sitemap generation.
NEXT_PUBLIC_DOMAIN=spondic.com

# ── Business Name ────────────────────────────────────────────────────────────
# Display name used across the website (header, footer, meta tags, legal pages).
NEXT_PUBLIC_BUSINESS_NAME=Spondic

# ── Free Trial Period ────────────────────────────────────────────────────────
# Number of days for the free trial (shown on pricing page).
NEXT_PUBLIC_TRIAL_PERIOD=30

# ── Google Analytics (Optional) ──────────────────────────────────────────────
# How to get it:
#   1. Go to https://analytics.google.com
#   2. Admin → Create Property → Web
#   3. Copy the Measurement ID (starts with G-)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# ── Sentry Error Tracking (Optional) ─────────────────────────────────────────
# How to get it:
#   1. Go to https://sentry.io → Create Project → Next.js
#   2. Copy the DSN from Project Settings → Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
